{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-IC:\\SFML-3.0.2\\include",
                
                // SOURCE FILES
                "${fileDirname}\\main.cpp",
                "${fileDirname}\\Simulation.cpp",
                "${fileDirname}\\FluidGrid.cpp",
                "${fileDirname}\\ToggleButton.cpp",
                "${fileDirname}\\Button.cpp",
                
                // SFML PATH
                "-LC:\\SFML-3.0.2\\lib",
                
                // SFML DEBUG LIBRARIES
                "-lsfml-graphics-d",
                "-lsfml-window-d",
                "-lsfml-system-d",
                
                // CRITICAL WINDOWS/SFML DEPENDENCIES
                "-lsfml-main-d",
                
                // OUTPUT
                "-o",
                "${fileDirname}\\main.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}